# Strava API (get from https://www.strava.com/settings/api)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_WEBHOOK_VERIFY_TOKEN=your-random-string

# Optional: only needed if triggering /api/strava/sync-all from an external cron job.
# The app has a built-in daily sync scheduler that doesn't require this.
STRAVA_SYNC_SECRET=

# App
DATABASE_URL=file:./farming.db
SESSION_SECRET=your-session-secret-change-me
NEXT_PUBLIC_APP_URL=http://localhost:3000
